provision:
	cd $(AM_REPOS_ROOT)/rust-am-clients && \
	cargo run --release --bin rust-rodeo-client -- -c $(CVM_EXE_PATH) \
		-r $(TOP_DIR)/attestation/provision.json \
		-e $(RODEO_ENVS_DIR)env_rodeo_micro_provision.json

